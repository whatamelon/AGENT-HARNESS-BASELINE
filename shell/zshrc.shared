# ~/.config/claude-sync/shell/zshrc.shared
# 두 맥북 공유 zshrc 엔트리.
# ~/.zshrc 는 1줄: `source ~/.config/claude-sync/shell/zshrc.shared`
# 머신별 추가는 ~/.zshrc.local 에서.

# ─── oh-my-zsh ─────────────────────────────────────────────
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="robbyrussell"
plugins=(git)
[ -f "$ZSH/oh-my-zsh.sh" ] && source $ZSH/oh-my-zsh.sh

# 커스텀 prompt (denny + 랜덤 이모지)
prompt_context() {
  emojis=("⚡️" "🔥" "😎" "💡" "🎉" "🌙")
  RAND_EMOJI_N=$(( $RANDOM % ${#emojis[@]} + 1))
  prompt_segment black default "{denny} ${emojis[$RAND_EMOJI_N]} "
}

# ─── 패키지 매니저 PATH ─────────────────────────────────────
export PNPM_HOME="$HOME/Library/pnpm"
case ":$PATH:" in *":$PNPM_HOME:"*) ;; *) export PATH="$PNPM_HOME:$PATH" ;; esac

export BUN_INSTALL="$HOME/.bun"
[ -d "$BUN_INSTALL/bin" ] && export PATH="$BUN_INSTALL/bin:$PATH"
[ -s "$BUN_INSTALL/_bun" ] && source "$BUN_INSTALL/_bun"

export PATH="$HOME/.local/bin:$PATH"
export PATH="/opt/homebrew/opt/postgresql@16/bin:$PATH"

# ─── 언어 런타임 ──────────────────────────────────────────
alias python=/usr/bin/python3
command -v rbenv >/dev/null && eval "$(rbenv init -)"

# Google Cloud SDK
if [ -d "$HOME/google-cloud-sdk" ]; then
  [ -f "$HOME/google-cloud-sdk/path.zsh.inc" ] && . "$HOME/google-cloud-sdk/path.zsh.inc"
  [ -f "$HOME/google-cloud-sdk/completion.zsh.inc" ] && . "$HOME/google-cloud-sdk/completion.zsh.inc"
fi

# Flutter pub-cache
[ -d "$HOME/.pub-cache" ] && export PATH="$PATH:$HOME/.pub-cache/bin"

# Java (Android Studio JBR — 머신에 있을 때만)
if [ -d "/Applications/Android Studio.app/Contents/jbr/Contents/Home" ]; then
  export JAVA_HOME="/Applications/Android Studio.app/Contents/jbr/Contents/Home"
  export PATH="$JAVA_HOME/bin:$PATH"
fi

# Antigravity (개인 맥북에만 있을 수 있음)
[ -d "$HOME/.antigravity/antigravity/bin" ] && export PATH="$HOME/.antigravity/antigravity/bin:$PATH"

# opencode
[ -d "$HOME/.opencode/bin" ] && export PATH="$HOME/.opencode/bin:$PATH"

# ─── alias ────────────────────────────────────────────────
alias fvrun='flutter run -d C6B43525-A483-4D8D-AC91-BCDCA67A2B1C'
alias claude-mem='bun "$HOME/.claude/plugins/marketplaces/thedotmack/plugin/scripts/worker-service.cjs"'
alias cs='cd ~/.config/claude-sync'
alias cs-sync='cd ~/.config/claude-sync && git pull --rebase --autostash && git diff --quiet || (git add . && git commit -m "auto: $(hostname -s) $(date +%FT%T)" && git push)'
alias cs-doctor='~/.config/claude-sync/bin/doctor.sh'
alias project-init='~/.config/claude-sync/bin/project-init.sh'
alias env-sync='~/.config/claude-sync/bin/env-sync.sh'
alias secrets-migrate='~/.config/claude-sync/bin/migrate-secrets-to-1password.sh'
alias saas-add='~/.config/claude-sync/bin/saas-add.sh'
alias install-apps='~/.config/claude-sync/bin/install-apps.sh'
alias export-desktop='~/.config/claude-sync/bin/export-desktop.sh'
alias import-desktop='~/.config/claude-sync/bin/import-desktop.sh'
alias mac-setup='~/.config/claude-sync/bin/mac-setup.sh'
alias 꾸쮹='~/.config/claude-sync/bin/mac-setup.sh'
alias codex-bridge='~/.config/claude-sync/bin/codex-bridge.sh'

# OMC team 계열 실행 전 Claude Code ↔ Codex 공유 상태를 먼저 맞춘다.
omc() {
  case "${1:-}" in
    team|swarm|ultrawork|ultrapilot)
      "$HOME/.config/claude-sync/bin/codex-bridge.sh" --quiet >/dev/null 2>&1 || true
      ;;
  esac
  command omc "$@"
}

# ─── 프로젝트별 시크릿 자동 로딩 (플러그인 패턴) ──────────
# shell/saas/*.sh 안의 모든 __load_<name>() 함수 자동 호출.
# 새 SaaS 추가: shell/saas/<name>.sh 파일 1개 만들기 (또는 saas-add <name>).
__load_project_secrets() {
  # 이전 export 정리
  if [[ -n "${PROJECT_SECRETS_EXPORTED:-}" ]]; then
    for v in ${(s: :)PROJECT_SECRETS_EXPORTED}; do
      unset "$v"
    done
    unset PROJECT_SECRETS_EXPORTED
  fi

  command -v jq >/dev/null || return 0

  local saas_dir="$HOME/.config/claude-sync/shell/saas"
  [[ -d "$saas_dir" ]] || return 0

  local exported=()
  local plugin name result

  for plugin in "$saas_dir"/*.sh; do
    [[ -f "$plugin" ]] || continue
    name="${${plugin:t}:r}"   # basename without .sh
    [[ "$name" == _* ]] && continue   # _lib.sh 등 헬퍼는 스킵
    source "$plugin"
    result=$("__load_$name" 2>/dev/null)
    if [[ -n "$result" ]]; then
      for v in ${(s: :)result}; do
        exported+=("$v")
      done
    fi
  done

  if (( ${#exported[@]} > 0 )); then
    export PROJECT_SECRETS_EXPORTED="${exported[*]}"
  fi
}
autoload -U add-zsh-hook
add-zsh-hook chpwd __load_project_secrets

# ─── 머신별 분기 ──────────────────────────────────────────
case "$(hostname -s)" in
  *)
    [ -f "$HOME/.config/claude-sync/shell/machines/$(hostname -s).sh" ] && \
      source "$HOME/.config/claude-sync/shell/machines/$(hostname -s).sh"
    ;;
esac

# ─── 로컬 머신 전용 (시크릿 등) ─────────────────────────
[ -f "$HOME/.zshrc.local" ] && source "$HOME/.zshrc.local"

# HUD: 두 맥북 상세 정보
alias hudm='$HOME/.config/claude-sync/bin/hud-machines.sh --format=detail'

# 셸 시작 시 1회 실행
__load_project_secrets

setopt PROMPT_SUBST

# ── HUD: 두 맥북 상태 RPROMPT segment ──────────────
__claude_sync_hud_rprompt() {
  [[ -x "$HOME/.config/claude-sync/bin/hud-machines.sh" ]] || return 0
  "$HOME/.config/claude-sync/bin/hud-machines.sh" --format=line 2>/dev/null
}

if [[ -z "${__CLAUDE_SYNC_RPROMPT_SET:-}" ]]; then
  RPROMPT="${RPROMPT:-}"'$(__claude_sync_hud_rprompt)'
  export __CLAUDE_SYNC_RPROMPT_SET=1
fi

# ── HUD: 출퇴근 catchup (4시간+ 휴면 후 1회) ──────────
__claude_sync_catchup() {
  [[ -x "$HOME/.config/claude-sync/bin/hud-catchup.sh" ]] || return 0
  local out
  out=$("$HOME/.config/claude-sync/bin/hud-catchup.sh" 2>/dev/null)
  [[ -n "$out" ]] && echo "$out"
}

if [[ -z "${__CLAUDE_SYNC_CATCHUP_HOOKED:-}" ]]; then
  autoload -Uz add-zsh-hook 2>/dev/null
  add-zsh-hook precmd __claude_sync_catchup 2>/dev/null
  export __CLAUDE_SYNC_CATCHUP_HOOKED=1
fi

# ── 첫 인사 모먼트 (mac-setup 완료 후 1회) ──────────
__maybe_greet() {
  [[ -x "$HOME/.config/claude-sync/bin/greet.sh" ]] || return 0
  local state="$HOME/.config/claude-sync/state/wizard-state.json"
  [[ -f "$state" ]] || return 0
  "$HOME/.config/claude-sync/bin/greet.sh" 2>/dev/null
}

if [[ -z "${__CLAUDE_SYNC_GREET_HOOKED:-}" ]]; then
  autoload -Uz add-zsh-hook 2>/dev/null
  add-zsh-hook precmd __maybe_greet 2>/dev/null
  export __CLAUDE_SYNC_GREET_HOOKED=1
fi

# 두 맥북 통합 활동 대시보드
alias activity='$HOME/.config/claude-sync/bin/activity.sh'

# ── 새 탭/셸 시작 시 백그라운드 sync (5분 throttle) ──
# launchd 30분 주기 외에, 탭을 열 때마다 최신 상태 보장.
# state 파일로 throttle해서 같은 머신에 탭 여러 개 열어도 1회만 실행.
__claude_sync_tab_pull() {
  [[ -x "$HOME/.config/claude-sync/bin/sync.sh" ]] || return 0
  local state_file="$HOME/.config/claude-sync/state/last-tab-sync.txt"
  local now last elapsed
  now=$(date +%s)
  last=0
  [[ -f "$state_file" ]] && last=$(cat "$state_file" 2>/dev/null || echo 0)
  elapsed=$((now - last))
  # 5분(300초) 이내 재실행 방지
  (( elapsed < 300 )) && return 0
  echo "$now" > "$state_file"
  # 완전 분리된 백그라운드 (셸 종료해도 살아있음, 출력 버림)
  ( nohup "$HOME/.config/claude-sync/bin/sync.sh" >/dev/null 2>&1 & ) &!
}

if [[ -z "${__CLAUDE_SYNC_TAB_PULL_DONE:-}" ]]; then
  __claude_sync_tab_pull
  export __CLAUDE_SYNC_TAB_PULL_DONE=1
fi
