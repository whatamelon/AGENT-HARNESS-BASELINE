{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 '/Users/manager/.codex/hooks/file-tracker.py'"
          },
          {
            "type": "command",
            "command": "bash $HOME/.config/claude-sync/bin/rebuild-agents-md.sh --quiet &"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 '/Users/manager/.codex/hooks/quality-check.py'"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/notify.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.config/claude-sync/bin/notify-session-end.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.config/claude-sync/bin/codex-bridge.sh --quiet --push &"
          }
        ]
      }
    ]
  }
}
