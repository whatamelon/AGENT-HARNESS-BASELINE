{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AIDP Evidence Source Index",
  "type": "object",
  "required": ["dossier_id", "customer", "created_at", "items"],
  "properties": {
    "dossier_id": {"type": "string"},
    "customer": {"type": "string"},
    "project": {"type": ["string", "null"]},
    "created_at": {"type": "string"},
    "scope": {"type": "object"},
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "source", "title", "evidence_type", "summary", "claims"],
        "properties": {
          "id": {"type": "string"},
          "source": {"enum": ["slack", "gmail", "drive", "calendar", "github", "file", "image", "web", "manual"]},
          "title": {"type": "string"},
          "uri": {"type": ["string", "null"]},
          "timestamp": {"type": ["string", "null"]},
          "speaker_role": {"enum": ["customer_decision_maker", "customer_operator", "customer_engineer", "internal_sales", "internal_engineer", "system", "unknown"]},
          "directness": {"enum": ["direct", "relayed", "inferred"]},
          "evidence_type": {"enum": ["rfp", "signed_doc", "customer_statement", "meeting_note", "email", "slack_thread", "calendar_event", "technical_artifact", "screenshot", "internal_note", "github_issue", "github_pr", "other"]},
          "summary": {"type": "string"},
          "claims": {"type": "array", "items": {"type": "string"}},
          "tags": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
