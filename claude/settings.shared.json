      "/tmp/supabase_temp_migrations"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/file-tracker.py"
          },
          {
            "type": "command",
            "command": "bash $HOME/.config/agent-harness-baseline/bin/rebuild-agents-md.sh --quiet &"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/quality-check.py"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/notify.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.config/agent-harness-baseline/bin/notify-session-end.sh &"
          },
          {
            "type": "command",
            "command": "bash $HOME/.config/agent-harness-baseline/bin/codex-bridge.sh --quiet --push &"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/notify.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node $HOME/.claude/hud/omc-hud.mjs"
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "vercel@claude-plugins-official": false,
    "oh-my-claudecode@omc": true,
    "superpowers@claude-plugins-official": true
  },
  "language": "한국어",
  "fastMode": true,
  "skipDangerousModePermissionPrompt": true,
  "model": "opus[1m]"
}
