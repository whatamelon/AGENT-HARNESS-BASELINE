{
  "_comment": "Example Claude Code hooks settings — merge into ~/.claude/settings.json or .claude/settings.local.json. Path is absolute; adjust if you keep the dispatcher elsewhere.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "python3 /Users/manager/.config/agent-harness-baseline/claude/hooks/admin_design_gate.py" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "python3 /Users/manager/.config/agent-harness-baseline/claude/hooks/admin_design_gate.py" }
        ]
      }
    ],
    "UserPromptExpansion": [
      {
        "matcher": "admin-build|admin-design|admin-design-verify",
        "hooks": [
          { "type": "command", "command": "python3 /Users/manager/.config/agent-harness-baseline/claude/hooks/admin_design_gate.py" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit|Bash",
        "hooks": [
          { "type": "command", "command": "python3 /Users/manager/.config/agent-harness-baseline/claude/hooks/admin_design_gate.py" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          { "type": "command", "command": "python3 /Users/manager/.config/agent-harness-baseline/claude/hooks/admin_design_gate.py" }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "python3 /Users/manager/.config/agent-harness-baseline/claude/hooks/admin_design_gate.py" }
        ]
      }
    ]
  }
}
