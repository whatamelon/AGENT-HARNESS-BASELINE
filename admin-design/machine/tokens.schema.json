{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "admin-design.tokens",
  "description": "Light-only neutral admin design tokens. Verifier checks CSS variables in :root match this schema; .dark blocks forbidden.",
  "type": "object",
  "required": ["radius", "background", "foreground", "card", "popover", "primary", "secondary", "muted", "accent", "destructive", "border", "input", "ring"],
  "properties": {
    "radius": { "type": "string", "enum": ["0.375rem", "0.5rem", "0.625rem"] },
    "background": { "$ref": "#/definitions/hsl-near-white" },
    "foreground": { "$ref": "#/definitions/hsl-near-black" },
    "card": { "$ref": "#/definitions/hsl-near-white" },
    "card-foreground": { "$ref": "#/definitions/hsl-near-black" },
    "popover": { "$ref": "#/definitions/hsl-near-white" },
    "popover-foreground": { "$ref": "#/definitions/hsl-near-black" },
    "primary": { "$ref": "#/definitions/hsl-any" },
    "primary-foreground": { "$ref": "#/definitions/hsl-near-white-or-black" },
    "secondary": { "$ref": "#/definitions/hsl-near-white" },
    "secondary-foreground": { "$ref": "#/definitions/hsl-near-black" },
    "muted": { "$ref": "#/definitions/hsl-near-white" },
    "muted-foreground": { "$ref": "#/definitions/hsl-mid-gray" },
    "accent": { "$ref": "#/definitions/hsl-near-white" },
    "accent-foreground": { "$ref": "#/definitions/hsl-near-black" },
    "destructive": { "$ref": "#/definitions/hsl-red" },
    "destructive-foreground": { "$ref": "#/definitions/hsl-near-white" },
    "border": { "$ref": "#/definitions/hsl-light-gray" },
    "input": { "$ref": "#/definitions/hsl-light-gray" },
    "ring": { "$ref": "#/definitions/hsl-any" },
    "success": { "$ref": "#/definitions/hsl-green" },
    "warning": { "$ref": "#/definitions/hsl-amber" },
    "info": { "$ref": "#/definitions/hsl-blue" }
  },
  "forbidden_keys": [".dark", "dark"],
  "definitions": {
    "hsl-near-white": { "type": "string", "pattern": "^\\d+(\\.\\d+)?\\s+\\d+(\\.\\d+)?%\\s+(9[0-9](\\.\\d+)?|100)%$" },
    "hsl-near-black": { "type": "string", "pattern": "^\\d+(\\.\\d+)?\\s+\\d+(\\.\\d+)?%\\s+([0-9]|1[0-5])(\\.\\d+)?%$" },
    "hsl-light-gray": { "type": "string", "pattern": "^\\d+(\\.\\d+)?\\s+\\d+(\\.\\d+)?%\\s+(8[0-9]|9[0-5])(\\.\\d+)?%$" },
    "hsl-mid-gray": { "type": "string", "pattern": "^\\d+(\\.\\d+)?\\s+\\d+(\\.\\d+)?%\\s+(3[0-9]|4[0-9]|5[0-9])(\\.\\d+)?%$" },
    "hsl-any": { "type": "string", "pattern": "^\\d+(\\.\\d+)?\\s+\\d+(\\.\\d+)?%\\s+\\d+(\\.\\d+)?%$" },
    "hsl-near-white-or-black": { "type": "string", "pattern": "^\\d+(\\.\\d+)?\\s+\\d+(\\.\\d+)?%\\s+(([0-9]|1[0-5])|9[0-9]|100)(\\.\\d+)?%$" },
    "hsl-red": { "type": "string", "pattern": "^(0|3[5-9][0-9])\\s+\\d+(\\.\\d+)?%\\s+\\d+(\\.\\d+)?%$" },
    "hsl-green": { "type": "string", "pattern": "^(1[0-4][0-9])\\s+\\d+(\\.\\d+)?%\\s+\\d+(\\.\\d+)?%$" },
    "hsl-amber": { "type": "string", "pattern": "^([2-4][0-9])\\s+\\d+(\\.\\d+)?%\\s+\\d+(\\.\\d+)?%$" },
    "hsl-blue": { "type": "string", "pattern": "^(2[0-5][0-9])\\s+\\d+(\\.\\d+)?%\\s+\\d+(\\.\\d+)?%$" }
  }
}
