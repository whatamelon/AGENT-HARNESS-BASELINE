# 시크릿
**/settings.local.json
**/.env
**/.env.*
!.env.example
**/.envrc
**/secrets/
**/*.secrets.*
**/*.pem
**/*.key
# 데스크톱 앱 시크릿 (실제 값 들어간 파일 — .tpl.json만 git 들어감)
desktop/claude-desktop/claude_desktop_config.json

# 로그/캐시 (혹시 모를 누수 방지)
**/cache/
**/sessions/
**/transcripts/
**/file-history/
**/paste-cache/
**/image-cache/
**/projects/
**/todos/
**/telemetry/
**/usage-data/
**/shell-snapshots/
**/session-env/
*.log
history.jsonl
.session-stats.json
__pycache__/
*.pyc

# OS / 에디터
.DS_Store
.idea/
.vscode/
*.swp
*~

# 백업
*.bak
*.bak.*

# 머신 페르소나 (머신별 다름)
.machine.json

# 에이전트 텔레메트리 (harness가 갱신하는 transient state)
.omc/state/

# HUD 캐시 (머신별 5s TTL)
state/hud-cache/*.txt

# HUD flash 마커 (머신별)
state/hud-flash.txt

# 머신별 prompt 시각 마커
state/last-prompt-ts.txt

# 머신별 tab pull throttle 마커 (zsh hook이 매 5분 갱신, 추적 시 양쪽 맥 race로 conflict marker 박힘)
state/last-tab-sync.txt

# Codex 메모리 — 전체 차단. codex-bridge.sh가 머신별로 매번 재생성하는
# 로컬 산출물이며 고객/PII 맥락이 섞일 수 있어 git 추적 금지(2026-05-18 히스토리 purge).
# 절대 git add 금지 — 전 디렉터리 ignore로 재유출 방지.
codex/memories/

# 머신별 sync 인증 결과
state/sync-attestation*.json

# 부트스트랩 wizard 메시지 ID (머신별, 일회용)
state/wizard-message-id.txt

# ahb-pause 로 만든 sync 일시정지 lock (머신별, 휘발성)
.sync-paused
