# 예시앱 — environment placeholders. Copy to `.env` and fill real values.
# NEVER commit `.env`. Only the PUBLIC anon/publishable keys belong on the client.
# (`service_role` and any secret must stay server-side.)
#
# The workspace `core` package reads SUPABASE_URL / SUPABASE_ANON_KEY from its
# own `.env` (packages/core/.env). This app-level file documents the app's
# extra placeholders; align with your `core` env when wiring the real backend.

SUPABASE_URL=
SUPABASE_ANON_KEY=
SENTRY_DSN=

# Toss Payments — pass via --dart-define at build time (test key in dev/staging).
# TOSS_CLIENT_KEY=

# Firebase Cloud Messaging — generated via FlutterFire CLI into
# lib/firebase_options.dart (git-ignored). No key belongs here.
