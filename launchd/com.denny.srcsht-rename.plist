<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.denny.srcsht-rename</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>__HOME__/.config/claude-sync/bin/srcsht-rename.sh</string>
    </array>
    <key>WatchPaths</key>
    <array>
        <string>__HOME__/srcsht</string>
    </array>
    <key>ThrottleInterval</key>
    <integer>1</integer>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>__HOME__/Library/Logs/srcsht-rename.log</string>
    <key>StandardErrorPath</key>
    <string>__HOME__/Library/Logs/srcsht-rename.log</string>
</dict>
</plist>
